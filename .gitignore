# ═══════════════════════════════════════════════════════════════════
# AttackShield-AI  –  .gitignore
# ═══════════════════════════════════════════════════════════════════

# ─── Environment & secrets ─────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.cert
secrets/

# ─── Python ────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd
.Python

# Virtual environments
.venv/
venv/
env/
ENV/
.python-version

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
*.whl
site-packages/

# Testing / coverage
.pytest_cache/
.coverage
htmlcov/
.tox/

# Jupyter
.ipynb_checkpoints/
*.ipynb

# ─── AI Models  (large binary files — store in Git-LFS or release) ─
*.pt
*.pth
*.onnx
*.tflite
*.h5
*.pkl
*.bin
*.weights
model/
models/
checkpoints/

# ─── Node.js / npm ─────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
package-lock.json
yarn.lock
pnpm-lock.yaml

# ─── Frontend build output ─────────────────────────────────────────
Frontend/dist/
Frontend/.vite/
Frontend/build/

# ─── HLS stream segments (runtime-generated, not source) ───────────
Backend/public/streams/**/seg_*.ts
Backend/public/streams/**/*.m3u8
Backend/public/streams/**/*.m4s
Backend/public/streams/**/*.tmp
# Keep the directory structure but not the files
!Backend/public/streams/.gitkeep

# ─── Logs ──────────────────────────────────────────────────────────
*.log
logs/
*.log.*

# ─── OS / editor artefacts ─────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini

.vscode/settings.json
.vscode/*.code-snippets
.idea/
*.swp
*.swo
*~
*.bak

# ─── TypeScript build cache ────────────────────────────────────────
*.tsbuildinfo
tsconfig.tsbuildinfo

# ─── Misc ──────────────────────────────────────────────────────────
.nyc_output/
.cache/
tmp/
temp/

# --- .NET / C# build output ---
[Bb]in/
[Oo]bj/
*.user
