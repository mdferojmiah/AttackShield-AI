{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "System.Net.Http.HttpClient": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ]
  },
  "Mongo": {
    "ConnectionString": "mongodb://localhost:27017",
    "Database": "weapon-detection"
  },
  "Jwt": {
    "Secret": "your-super-secret-jwt-key-change-in-production-min-32-chars",
    "Issuer": "AttackShield",
    "Audience": "AttackShield",
    "ExpireDays": 7
  },
  "Google": {
    "ClientId": "",
    "ClientSecret": ""
  },
  "Cors": {
    "AllowedOrigins": [ "*" ]
  },
  "Ai": {
    "BaseUrl": "http://localhost:8000"
  },
  "Frontend": {
    "BaseUrl": "http://localhost:3000"
  },
  "Backend": {
    "BaseUrl": "http://localhost:5000"
  },
  "Stream": {
    "StreamsRoot": "wwwroot/streams",
    "FfmpegPath": ""
  },
  "AllowedHosts": "*"
}
